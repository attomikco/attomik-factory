{% comment %}
  Configurable product checklist with optional value prop highlight.

  Usage:
    {% render 'product-checklist',
      block: block,
      color_scheme: block.settings.color_scheme
    %}

  Parameters:
    block          — the Shopify block object with settings (item_1..item_5, value_prop_tag, value_prop_text)
    color_scheme   — theme color scheme class
{% endcomment %}

<div class="{{ color_scheme }} product-checklist" {{ block.shopify_attributes }} style="border: 1px solid red;">
  <ul class="product-checklist__list">
    {% if block.settings.item_1 != blank %}
      <li class="product-checklist__item">
        <span class="product-checklist__ck" aria-hidden="true">&#10003;</span>
        <span>{{ block.settings.item_1 }}</span>
      </li>
    {% endif %}
    {% if block.settings.item_2 != blank %}
      <li class="product-checklist__item">
        <span class="product-checklist__ck" aria-hidden="true">&#10003;</span>
        <span>{{ block.settings.item_2 }}</span>
      </li>
    {% endif %}
    {% if block.settings.item_3 != blank %}
      <li class="product-checklist__item">
        <span class="product-checklist__ck" aria-hidden="true">&#10003;</span>
        <span>{{ block.settings.item_3 }}</span>
      </li>
    {% endif %}
    {% if block.settings.item_4 != blank %}
      <li class="product-checklist__item">
        <span class="product-checklist__ck" aria-hidden="true">&#10003;</span>
        <span>{{ block.settings.item_4 }}</span>
      </li>
    {% endif %}
    {% if block.settings.item_5 != blank %}
      <li class="product-checklist__item">
        <span class="product-checklist__ck" aria-hidden="true">&#10003;</span>
        <span>{{ block.settings.item_5 }}</span>
      </li>
    {% endif %}
    {% if block.settings.value_prop_text != blank %}
      <li class="product-checklist__val">
        <span class="product-checklist__tag">{{ block.settings.value_prop_tag | default: '★ Best Value' }}</span>
        <span class="product-checklist__val-text">{{ block.settings.value_prop_text }}</span>
      </li>
    {% endif %}
  </ul>
</div>

{% style %}
  .product-checklist__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
    font-family: var(--font-body-family);
  }
  .product-checklist__item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: calc(0.9375 * var(--font-body-scale) * 1rem);
    font-weight: var(--font-body-weight-bold);
    color: var(--color-foreground);
  }
  .product-checklist__ck {
    width: 20px;
    height: 20px;
    min-width: 20px;
    border-radius: 50%;
    background: var(--color-foreground);
    color: var(--color-background);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: calc(0.625 * var(--font-body-scale) * 1rem);
    font-weight: var(--font-body-weight-bold);
  }
  .product-checklist__val {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 4px;
    padding: 8px 12px;
    background: color-mix(in srgb, var(--color-foreground) 6%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-foreground) 15%, transparent);
    border-radius: var(--inputs-radius, 6px);
    font-family: var(--font-body-family);
  }
  .product-checklist__tag {
    background: var(--color-foreground);
    color: var(--color-background);
    font-family: var(--font-body-family);
    font-size: calc(0.5625 * var(--font-body-scale) * 1rem);
    font-weight: var(--font-body-weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    padding: 2px 6px;
    border-radius: 3px;
    white-space: nowrap;
  }
  .product-checklist__val-text {
    font-size: calc(0.9375 * var(--font-body-scale) * 1rem);
    font-weight: var(--font-body-weight-bold);
    color: var(--color-foreground);
  }
  @media (max-width: 768px) {
    .product-checklist__item {
      font-size: calc(0.875 * var(--font-body-scale) * 1rem);
    }
    .product-checklist__val-text {
      font-size: calc(0.875 * var(--font-body-scale) * 1rem);
    }
  }
{% endstyle %}
