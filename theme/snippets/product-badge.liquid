<!-- snippets/product-badge.liquid -->
{% comment %}
  Product eyebrow badge using the theme's native component__badge.

  Accepts:
  - block: {object} The block object with settings.

  Usage:
    {% render 'product-badge', block: block %}
{% endcomment %}

{% liquid
  assign badge_label = block.settings.badge_text | default: 'Badge'
  assign badge_icon = block.settings.icon | default: ''
%}

<div
  class="
    w-full px-4
    {{ block.settings.color_scheme }}
    {{ block.settings.color_border }}
    {{ block.settings.style_border }}
  "
  style="
    padding-top:{{ block.settings.spacing_top }}px;
    padding-bottom:{{ block.settings.spacing_bottom }}px;
  "
  {{ block.shopify_attributes }}
>
  {% render 'component__badge',
    background: block.settings.badge_background,
    text: block.settings.badge_text_color,
    border: block.settings.badge_border_color,
    icon: badge_icon,
    content: badge_label
  %}
</div>
