    "font_heading": "syne_n7",
    "font_body": "dm_sans_n4",
    "font_accent": "'Georgia', 'Times New Roman', serif",
    "scale_heading_desktop": 100,
    "scale_heading_mobile": 100,
    "scale_body": 100,
    "width_content": 1200,
    "width_narrow": 720,
    "width_wide": 1440,
    "section_vertical_padding": 80,
    "grid_gap": 24,
    "radius_sm": 4,
