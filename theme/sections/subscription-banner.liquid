{%- liquid
  assign layout = section.settings.layout
  assign eyebrow = section.settings.eyebrow
  assign headline = section.settings.headline
  assign cta_label = section.settings.cta_label
  assign cta_url = section.settings.cta_url
  assign fine_print = section.settings.fine_print
  assign bg_color = section.settings.background_color
  assign bg_image = section.settings.background_image
  assign overlay_opacity = section.settings.overlay_opacity | times: 0.01
  assign text_color = section.settings.text_color

  if text_color == 'light'
    assign text_class = 'sub-banner--light'
  else
    assign text_class = 'sub-banner--dark'
  endif
-%}

{%- capture svg_check -%}
<svg class="sub-banner__check" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
{%- endcapture -%}

<section
  class="sub-banner sub-banner--{{ layout }} {{ text_class }}"
  id="section-{{ section.id }}"
  data-section-id="{{ section.id }}"
  data-section-type="subscription-banner"
  style="--sub-bg: {{ bg_color }};"
>
  {%- if bg_image != blank -%}
    <div class="sub-banner__bg">
      <img
        class="sub-banner__bg-image"
        src="{{ bg_image | image_url: width: 2400 }}"
        srcset="
          {{ bg_image | image_url: width: 900 }} 900w,
          {{ bg_image | image_url: width: 1400 }} 1400w,
          {{ bg_image | image_url: width: 2400 }} 2400w
        "
        sizes="100vw"
        alt=""
        loading="lazy"
      >
      <div class="sub-banner__overlay" style="opacity: {{ overlay_opacity }};"></div>
    </div>
  {%- endif -%}

  <div class="section-container sub-banner__container">
    <div class="sub-banner__content">
      {%- if eyebrow != blank -%}
        <span class="sub-banner__eyebrow">{{ eyebrow }}</span>
      {%- endif -%}

      {%- if headline != blank -%}
        <h2 class="sub-banner__headline">{{ headline }}</h2>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <ul class="sub-banner__benefits">
          {%- for block in section.blocks -%}
            <li class="sub-banner__benefit" {{ block.shopify_attributes }}>
              {{ svg_check }}
              <span>{{ block.settings.text }}</span>
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}

      {%- if cta_label != blank -%}
        <a href="{{ cta_url }}" class="btn-primary sub-banner__cta">{{ cta_label }}</a>
      {%- endif -%}

      {%- if fine_print != blank -%}
        <p class="sub-banner__fine-print">{{ fine_print }}</p>
      {%- endif -%}
    </div>

    {%- if layout == 'split' and section.settings.split_image != blank -%}
      <div class="sub-banner__split-image">
        <img
          src="{{ section.settings.split_image | image_url: width: 800 }}"
          alt=""
          loading="lazy"
          width="{{ section.settings.split_image.width }}"
          height="{{ section.settings.split_image.height }}"
        >
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  .sub-banner {
    position: relative;
    background-color: var(--sub-bg);
    padding-top: var(--section-gap-lg);
    padding-bottom: var(--section-gap-lg);
    overflow: hidden;
  }

  /* Background image */
  .sub-banner__bg {
    position: absolute;
    inset: 0;
    z-index: var(--z-base);
  }

  .sub-banner__bg-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .sub-banner__overlay {
    position: absolute;
    inset: 0;
    background-color: #000;
    pointer-events: none;
  }

  /* Container */
  .sub-banner__container {
    position: relative;
    z-index: var(--z-dropdown);
  }

  /* Text color variants */
  .sub-banner--light { color: var(--color-text-inverse); }
  .sub-banner--dark  { color: var(--color-text); }

  .sub-banner--light .sub-banner__headline { color: var(--color-text-inverse); }
  .sub-banner--dark  .sub-banner__headline { color: var(--color-text); }

  /* Centered layout */
  .sub-banner--centered .sub-banner__content {
    text-align: center;
    max-width: var(--width-narrow);
    margin-left: auto;
    margin-right: auto;
  }

  .sub-banner--centered .sub-banner__benefits {
    display: inline-flex;
    flex-direction: column;
    text-align: left;
  }

  .sub-banner--centered .sub-banner__cta {
    margin-left: auto;
    margin-right: auto;
  }

  /* Split layout */
  .sub-banner--split .sub-banner__container {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-7);
    align-items: center;
  }

  /* Eyebrow */
  .sub-banner__eyebrow {
    display: inline-block;
    margin-bottom: var(--space-3);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    opacity: 0.8;
  }

  /* Headline */
  .sub-banner__headline {
    margin-bottom: var(--space-5);
  }

  /* Benefits list */
  .sub-banner__benefits {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-bottom: var(--space-6);
  }

  .sub-banner__benefit {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--text-base);
    font-weight: var(--weight-medium);
  }

  .sub-banner__check {
    flex-shrink: 0;
    color: var(--color-accent-light);
  }

  .sub-banner--dark .sub-banner__check {
    color: var(--color-accent);
  }

  /* CTA */
  .sub-banner__cta {
    display: inline-flex;
  }

  .sub-banner--light .sub-banner__cta {
    background-color: var(--color-text-inverse);
    color: var(--color-primary);
    border-color: var(--color-text-inverse);
  }

  .sub-banner--light .sub-banner__cta:hover {
    background-color: var(--color-bg-alt);
    border-color: var(--color-bg-alt);
  }

  /* Fine print */
  .sub-banner__fine-print {
    margin-top: var(--space-3);
    font-size: var(--text-xs);
    opacity: 0.6;
  }

  /* Split image */
  .sub-banner__split-image {
    display: none;
  }

  .sub-banner__split-image img {
    width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
  }

  /* Desktop split */
  @media (min-width: 768px) {
    .sub-banner--split .sub-banner__container {
      grid-template-columns: 1fr 1fr;
    }

    .sub-banner__split-image {
      display: block;
    }
  }
</style>

{% schema %}
{
  "name": "Subscription Banner",
  "tag": "section",
  "class": "section-subscription-banner",
  "settings": [
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "centered", "label": "Centered" },
        { "value": "split", "label": "Split (content + image)" }
      ],
      "default": "centered"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Subscribe & Save"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Never Run Out — Get 20% Off Every Order"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Start Your Subscription"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button link"
    },
    {
      "type": "text",
      "id": "fine_print",
      "label": "Fine print",
      "default": "Cancel anytime. Free shipping on all subscription orders.",
      "info": "Optional small text below the CTA."
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#1A1A1A"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image",
      "info": "Optional — overlays the background color."
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 70,
      "step": 5,
      "default": 40,
      "unit": "%"
    },
    {
      "type": "select",
      "id": "text_color",
      "label": "Text color",
      "options": [
        { "value": "light", "label": "Light (on dark bg)" },
        { "value": "dark", "label": "Dark (on light bg)" }
      ],
      "default": "light"
    },
    {
      "type": "image_picker",
      "id": "split_image",
      "label": "Split layout image",
      "info": "Only shown in split layout on desktop."
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Benefit text",
          "default": "Benefit"
        }
      ]
    }
  ],
  "max_blocks": 5,
  "presets": [
    {
      "name": "Subscription Banner",
      "category": "Conversion",
      "blocks": [
        { "type": "benefit", "settings": { "text": "20% off every order" } },
        { "type": "benefit", "settings": { "text": "Free shipping, always" } },
        { "type": "benefit", "settings": { "text": "Skip or pause anytime" } },
        { "type": "benefit", "settings": { "text": "Exclusive subscriber flavors" } }
      ]
    }
  ]
}
{% endschema %}
