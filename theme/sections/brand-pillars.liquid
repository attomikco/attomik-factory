{%- liquid
  assign section_title = section.settings.section_title
  assign columns = section.settings.columns
  assign show_dividers = section.settings.show_dividers
  assign bg_color = section.settings.background
  assign text_align = section.settings.text_align
-%}

<section
  class="brand-pillars brand-pillars--align-{{ text_align }}"
  id="section-{{ section.id }}"
  data-section-id="{{ section.id }}"
  data-section-type="brand-pillars"
  style="
    --pillars-bg: {{ bg_color }};
    --pillars-columns: {{ columns }};
  "
>
  <div class="section-container">
    {%- if section_title != blank -%}
      <h2 class="brand-pillars__title">{{ section_title }}</h2>
    {%- endif -%}

    <div class="brand-pillars__grid{% if show_dividers %} brand-pillars__grid--dividers{% endif %}">
      {%- for block in section.blocks -%}
        <div class="brand-pillars__item" {{ block.shopify_attributes }}>
          {%- if block.settings.icon != blank -%}
            <div class="brand-pillars__icon">
              <img
                src="{{ block.settings.icon | image_url: width: 96 }}"
                alt="{{ block.settings.headline | escape }}"
                width="48"
                height="48"
                loading="lazy"
              >
            </div>
          {%- endif -%}

          {%- if block.settings.headline != blank -%}
            <h3 class="brand-pillars__headline">{{ block.settings.headline }}</h3>
          {%- endif -%}

          {%- if block.settings.description != blank -%}
            <p class="brand-pillars__description">{{ block.settings.description }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .brand-pillars {
    background-color: var(--pillars-bg);
    padding-top: var(--section-gap-md);
    padding-bottom: var(--section-gap-md);
  }

  /* Section title */
  .brand-pillars__title {
    text-align: center;
    margin-bottom: var(--space-8);
  }

  /* Grid */
  .brand-pillars__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-7);
  }

  /* Dividers — vertical borders between columns, desktop only */
  @media (min-width: 768px) {
    .brand-pillars__grid--dividers .brand-pillars__item {
      border-right: var(--border-width) solid var(--color-border);
      padding-right: var(--space-6);
    }

    .brand-pillars__grid--dividers .brand-pillars__item:last-child {
      border-right: none;
      padding-right: 0;
    }
  }

  /* Item */
  .brand-pillars__item {
    display: flex;
    flex-direction: column;
  }

  /* Alignment */
  .brand-pillars--align-center .brand-pillars__item {
    align-items: center;
    text-align: center;
  }

  .brand-pillars--align-left .brand-pillars__item {
    align-items: flex-start;
    text-align: left;
  }

  /* Icon */
  .brand-pillars__icon {
    width: 48px;
    height: 48px;
    margin-bottom: var(--space-4);
    flex-shrink: 0;
  }

  .brand-pillars__icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  /* Headline */
  .brand-pillars__headline {
    font-size: var(--text-lg);
    font-weight: var(--weight-semibold);
    margin-bottom: var(--space-2);
  }

  /* Description */
  .brand-pillars__description {
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    color: var(--color-text-secondary);
    max-width: 320px;
  }

  .brand-pillars--align-center .brand-pillars__description {
    margin-left: auto;
    margin-right: auto;
  }

  /* Tablet — 2 columns */
  @media (min-width: 768px) {
    .brand-pillars__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-6);
    }
  }

  /* Desktop — full column count */
  @media (min-width: 1200px) {
    .brand-pillars__grid {
      grid-template-columns: repeat(var(--pillars-columns), 1fr);
    }
  }
</style>

{% schema %}
{
  "name": "Brand Pillars",
  "tag": "section",
  "class": "section-brand-pillars",
  "settings": [
    {
      "type": "text",
      "id": "section_title",
      "label": "Section title",
      "info": "Optional — displayed centered above the grid."
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns",
      "options": [
        { "value": "3", "label": "3 columns" },
        { "value": "4", "label": "4 columns" }
      ],
      "default": "3"
    },
    {
      "type": "checkbox",
      "id": "show_dividers",
      "label": "Show dividers between columns",
      "default": false
    },
    {
      "type": "color",
      "id": "background",
      "label": "Background color",
      "default": "#FFFFFF"
    },
    {
      "type": "select",
      "id": "text_align",
      "label": "Text alignment",
      "options": [
        { "value": "center", "label": "Center" },
        { "value": "left", "label": "Left" }
      ],
      "default": "center"
    }
  ],
  "blocks": [
    {
      "type": "pillar",
      "name": "Pillar",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon",
          "info": "Upload an SVG or PNG icon. Displays at 48×48px."
        },
        {
          "type": "text",
          "id": "headline",
          "label": "Headline",
          "default": "Benefit"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "A short sentence about this brand benefit."
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Brand Pillars",
      "category": "Text",
      "blocks": [
        {
          "type": "pillar",
          "settings": {
            "headline": "Clean Ingredients",
            "description": "Every ingredient is carefully sourced and third-party tested for purity."
          }
        },
        {
          "type": "pillar",
          "settings": {
            "headline": "Sustainable Process",
            "description": "Carbon-neutral production from farm to shelf, with fully recyclable packaging."
          }
        },
        {
          "type": "pillar",
          "settings": {
            "headline": "Proven Results",
            "description": "Backed by clinical research and trusted by thousands of customers daily."
          }
        }
      ]
    }
  ]
}
{% endschema %}
