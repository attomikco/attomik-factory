{%- liquid
  assign section_title = section.settings.section_title
  assign section_subtitle = section.settings.section_subtitle
  assign collection = section.settings.collection
  assign limit = section.settings.products_to_show
  assign show_rating = section.settings.show_rating
  assign show_unit_price = section.settings.show_unit_price
  assign bg_color = section.settings.background
-%}

<section
  class="product-collection"
  id="section-{{ section.id }}"
  data-section-id="{{ section.id }}"
  data-section-type="product-collection"
  style="--pc-bg: {{ bg_color }};"
>
  <div class="section-container">
    {%- if section_title != blank or section_subtitle != blank -%}
      <div class="product-collection__header">
        {%- if section_title != blank -%}
          <h2 class="product-collection__title">{{ section_title }}</h2>
        {%- endif -%}
        {%- if section_subtitle != blank -%}
          <p class="product-collection__subtitle">{{ section_subtitle }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if collection != blank and collection.products.size > 0 -%}
      <div class="product-collection__grid">
        {%- for product in collection.products limit: limit -%}
          {%- assign lazy = true -%}
          {%- if forloop.index <= 2 -%}
            {%- assign lazy = false -%}
          {%- endif -%}
          {%- render 'product-card',
            product: product,
            show_rating: show_rating,
            show_unit_price: show_unit_price,
            lazy: lazy
          -%}
        {%- endfor -%}
      </div>
    {%- else -%}
      <div class="product-collection__grid">
        {%- for i in (1..limit) -%}
          <div class="product-card product-card--placeholder">
            <div class="product-card__media">
              {{ 'product-1' | placeholder_svg_tag: 'product-card__placeholder' }}
            </div>
            <div class="product-card__info">
              <h3 class="product-card__title">Example Product</h3>
              <div class="price">
                <div class="price__row">
                  <span class="price__current">{{ 2999 | money }}</span>
                </div>
              </div>
              <button class="product-card__atc btn-primary" disabled>
                <span>Add to Cart</span>
              </button>
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  .product-collection {
    background-color: var(--pc-bg);
    padding-top: var(--section-gap-md);
    padding-bottom: var(--section-gap-md);
  }

  /* Header */
  .product-collection__header {
    text-align: center;
    margin-bottom: var(--space-8);
  }

  .product-collection__title {
    margin-bottom: var(--space-3);
  }

  .product-collection__subtitle {
    max-width: var(--width-narrow);
    margin-left: auto;
    margin-right: auto;
    color: var(--color-text-secondary);
  }

  /* Grid */
  .product-collection__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-5);
  }

  /* --------------------------------------------------------------------------
     Product card styles
     -------------------------------------------------------------------------- */

  .product-card {
    display: flex;
    flex-direction: column;
    border: var(--border-width) solid var(--color-border);
    border-radius: var(--radius-md);
    background-color: var(--color-bg);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
    transition: box-shadow var(--transition-base);
  }

  .product-card:hover {
    box-shadow: var(--shadow-md);
  }

  /* Media */
  .product-card__media-link {
    display: block;
  }

  .product-card__media {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background-color: var(--color-bg-alt);
  }

  .product-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product-card__image--hover {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .product-card__media--has-hover:hover .product-card__image--hover {
    opacity: 1;
  }

  .product-card__placeholder {
    width: 100%;
    height: 100%;
  }

  /* Sale badge */
  .product-card__badge {
    position: absolute;
    top: var(--space-2);
    left: var(--space-2);
    padding: var(--space-1) var(--space-2);
    background-color: var(--color-error);
    color: var(--color-text-inverse);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    border-radius: var(--radius-sm);
    line-height: 1;
  }

  /* Info */
  .product-card__info {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-4);
    flex-grow: 1;
  }

  .product-card__title-link {
    display: block;
  }

  .product-card__title {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    line-height: var(--leading-snug);
  }

  /* Rating */
  .rating-stars {
    display: flex;
    align-items: center;
    gap: var(--space-1);
  }

  .rating-stars__icons {
    display: flex;
    gap: 1px;
    color: var(--color-secondary);
  }

  .rating-stars__star--empty {
    opacity: 0.35;
  }

  .rating-stars__count {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  /* Price */
  .price__row {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
  }

  .price__current {
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    color: var(--color-text);
  }

  .price--on-sale .price__current {
    color: var(--color-error);
  }

  s.price__compare {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-decoration: line-through;
  }

  .price__unit {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  /* Variant pills */
  .product-card__variants {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
  }

  .product-card__variant-pill {
    padding: var(--space-1) var(--space-2);
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    line-height: 1;
    border: var(--border-width) solid var(--color-border);
    border-radius: var(--radius-full);
    background: transparent;
    cursor: pointer;
    transition: border-color var(--transition-fast), background-color var(--transition-fast);
  }

  .product-card__variant-pill--active {
    border-color: var(--color-primary);
    background-color: var(--color-primary);
    color: var(--color-text-inverse);
  }

  .product-card__variant-pill--unavailable {
    opacity: 0.4;
    cursor: not-allowed;
    text-decoration: line-through;
  }

  /* Add to cart */
  .product-card__atc {
    width: 100%;
    margin-top: auto;
    padding-top: var(--space-3);
    padding-bottom: var(--space-3);
  }

  .product-card__atc[disabled] {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .product-card__atc--loading {
    pointer-events: none;
    opacity: 0.7;
  }

  .product-card__atc--success {
    background-color: var(--color-success);
    border-color: var(--color-success);
  }

  /* --------------------------------------------------------------------------
     Mobile — 1.5 columns (partial card visible)
     -------------------------------------------------------------------------- */

  @media (max-width: 767px) {
    .product-collection__grid {
      grid-template-columns: repeat(2, 1fr);
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      margin-right: calc(-1 * var(--space-4));
      padding-right: var(--space-4);
    }

    .product-collection__grid {
      grid-template-columns: repeat(auto-fill, minmax(65%, 1fr));
      grid-auto-flow: column;
      grid-auto-columns: minmax(65%, 1fr);
    }

    .product-card {
      scroll-snap-align: start;
    }
  }

  /* Tablet — 2 columns */
  @media (min-width: 768px) {
    .product-collection__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* Desktop — 4 columns */
  @media (min-width: 1200px) {
    .product-collection__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>

{% schema %}
{
  "name": "Product Collection",
  "tag": "section",
  "class": "section-product-collection",
  "settings": [
    {
      "type": "text",
      "id": "section_title",
      "label": "Title",
      "default": "Shop Our Bestsellers"
    },
    {
      "type": "textarea",
      "id": "section_subtitle",
      "label": "Subtitle",
      "info": "Optional description below the title."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 4,
      "max": 12,
      "step": 1,
      "default": 6
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "Show star ratings",
      "default": true,
      "info": "Requires reviews.rating metafield."
    },
    {
      "type": "checkbox",
      "id": "show_unit_price",
      "label": "Show unit price",
      "default": true,
      "info": "Displays per-unit pricing when configured on the variant."
    },
    {
      "type": "color",
      "id": "background",
      "label": "Background color",
      "default": "#FFFFFF"
    }
  ],
  "presets": [
    {
      "name": "Product Collection",
      "category": "Products"
    }
  ]
}
{% endschema %}
