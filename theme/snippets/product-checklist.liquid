<!-- snippets/product-checklist.liquid -->
{% comment %}
  Product checklist using theme-native icon and text patterns.

  Accepts:
  - block: {object} The block object with settings.

  Usage:
    {% render 'product-checklist', block: block %}
{% endcomment %}

<div
  class="
    w-full px-4
    {{ block.settings.color_scheme }}
    {{ block.settings.color_border }}
    {{ block.settings.style_border }}
  "
  style="
    padding-top:{{ block.settings.spacing_top }}px;
    padding-bottom:{{ block.settings.spacing_bottom }}px;
  "
  {{ block.shopify_attributes }}
>
  <div class="flex flex-col gap-2">
    {% assign items = '' %}
    {% if block.settings.item_1 != blank %}{% assign items = items | append: block.settings.item_1 | append: '|||' %}{% endif %}
    {% if block.settings.item_2 != blank %}{% assign items = items | append: block.settings.item_2 | append: '|||' %}{% endif %}
    {% if block.settings.item_3 != blank %}{% assign items = items | append: block.settings.item_3 | append: '|||' %}{% endif %}
    {% if block.settings.item_4 != blank %}{% assign items = items | append: block.settings.item_4 | append: '|||' %}{% endif %}
    {% if block.settings.item_5 != blank %}{% assign items = items | append: block.settings.item_5 | append: '|||' %}{% endif %}
    {% assign items_array = items | split: '|||' %}

    {% for item in items_array %}
      <div class="flex items-center gap-2">
        {% render 'component__icon', icon: 'check', size: '14' %}
        <span class="type--small">{{ item }}</span>
      </div>
    {% endfor %}

    {% if block.settings.value_prop_text != blank %}
      <div class="color__bg-shade-1 border__element--radius mt-1 flex items-center gap-2 p-2">
        {% unless block.settings.value_prop_tag == blank %}
          {% render 'component__badge',
            background: 'body',
            text: 'body',
            border: 'body',
            content: block.settings.value_prop_tag
          %}
        {% endunless %}
        <span class="type--small">{{ block.settings.value_prop_text }}</span>
      </div>
    {% endif %}
  </div>
</div>
