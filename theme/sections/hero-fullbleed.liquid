{%- liquid
  assign layout = section.settings.layout
  assign height = section.settings.section_height
  assign overlay_opacity = section.settings.overlay_opacity | times: 0.01
  assign image = section.settings.image
  assign eyebrow = section.settings.eyebrow
  assign headline = section.settings.headline
  assign subheadline = section.settings.subheadline
  assign cta_primary_label = section.settings.cta_primary_label
  assign cta_primary_url = section.settings.cta_primary_url
  assign cta_secondary_label = section.settings.cta_secondary_label
  assign cta_secondary_url = section.settings.cta_secondary_url

  case height
    when 'full'
      assign height_class = 'hero-fullbleed--full'
    when 'large'
      assign height_class = 'hero-fullbleed--large'
    when 'medium'
      assign height_class = 'hero-fullbleed--medium'
  endcase

  if layout == 'image_left'
    assign layout_class = 'hero-fullbleed--img-left'
  else
    assign layout_class = 'hero-fullbleed--img-right'
  endif
-%}

<section
  class="hero-fullbleed {{ height_class }} {{ layout_class }}"
  id="section-{{ section.id }}"
  data-section-id="{{ section.id }}"
  data-section-type="hero-fullbleed"
>
  <div class="hero-fullbleed__media">
    {%- if image != blank -%}
      <img
        class="hero-fullbleed__image"
        src="{{ image | image_url: width: 2400 }}"
        srcset="
          {{ image | image_url: width: 900 }} 900w,
          {{ image | image_url: width: 1200 }} 1200w,
          {{ image | image_url: width: 1800 }} 1800w,
          {{ image | image_url: width: 2400 }} 2400w
        "
        sizes="100vw"
        alt="{{ image.alt | escape }}"
        width="{{ image.width }}"
        height="{{ image.height }}"
        loading="eager"
        fetchpriority="high"
      >
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'hero-fullbleed__placeholder' }}
    {%- endif -%}
    <div class="hero-fullbleed__overlay" style="opacity: {{ overlay_opacity }};"></div>
  </div>

  <div class="hero-fullbleed__content section-container">
    <div class="hero-fullbleed__content-inner">
      {%- if eyebrow != blank -%}
        <span class="hero-fullbleed__eyebrow">{{ eyebrow }}</span>
      {%- endif -%}

      {%- if headline != blank -%}
        <h1 class="hero-fullbleed__headline">{{ headline }}</h1>
      {%- endif -%}

      {%- if subheadline != blank -%}
        <p class="hero-fullbleed__subheadline">{{ subheadline }}</p>
      {%- endif -%}

      {%- if cta_primary_label != blank or cta_secondary_label != blank -%}
        <div class="hero-fullbleed__ctas">
          {%- if cta_primary_label != blank -%}
            <a href="{{ cta_primary_url }}" class="btn-primary">{{ cta_primary_label }}</a>
          {%- endif -%}
          {%- if cta_secondary_label != blank -%}
            <a href="{{ cta_secondary_url }}" class="btn-secondary hero-fullbleed__btn-secondary">{{ cta_secondary_label }}</a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  .hero-fullbleed {
    position: relative;
    display: grid;
    grid-template-columns: 1fr;
    overflow: hidden;
    background-color: var(--color-bg-dark);
  }

  .hero-fullbleed--full   { min-height: 100vh; }
  .hero-fullbleed--large  { min-height: 80vh; }
  .hero-fullbleed--medium { min-height: 60vh; }

  /* Media layer */
  .hero-fullbleed__media {
    position: absolute;
    inset: 0;
    z-index: var(--z-base);
  }

  .hero-fullbleed__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-fullbleed__placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    background-color: var(--color-bg-alt);
  }

  .hero-fullbleed__overlay {
    position: absolute;
    inset: 0;
    background-color: #000;
    pointer-events: none;
  }

  /* Content layer */
  .hero-fullbleed__content {
    position: relative;
    z-index: var(--z-dropdown);
    display: flex;
    align-items: center;
    min-height: inherit;
    padding-top: var(--space-10);
    padding-bottom: var(--space-10);
  }

  .hero-fullbleed__content-inner {
    max-width: 640px;
  }

  .hero-fullbleed--img-left .hero-fullbleed__content {
    justify-content: flex-end;
  }

  .hero-fullbleed--img-right .hero-fullbleed__content {
    justify-content: flex-start;
  }

  /* Eyebrow */
  .hero-fullbleed__eyebrow {
    display: inline-block;
    margin-bottom: var(--space-3);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--color-text-inverse);
    opacity: 0.85;
  }

  /* Headline */
  .hero-fullbleed__headline {
    color: var(--color-text-inverse);
    margin-bottom: var(--space-4);
    animation: heroFadeUp var(--duration-slower) var(--ease-out) both;
  }

  /* Subheadline */
  .hero-fullbleed__subheadline {
    font-size: var(--text-md);
    line-height: var(--leading-relaxed);
    color: var(--color-text-inverse);
    opacity: 0.85;
    margin-bottom: var(--space-6);
    max-width: 520px;
    animation: heroFadeUp var(--duration-slower) var(--ease-out) 100ms both;
  }

  /* CTAs */
  .hero-fullbleed__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    animation: heroFadeUp var(--duration-slower) var(--ease-out) 200ms both;
  }

  .hero-fullbleed__btn-secondary {
    color: var(--color-text-inverse);
    border-color: var(--color-text-inverse);
  }

  .hero-fullbleed__btn-secondary:hover {
    background-color: var(--color-text-inverse);
    color: var(--color-primary);
  }

  /* Fade-up animation */
  @keyframes heroFadeUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Tablet */
  @media (min-width: 768px) {
    .hero-fullbleed__content-inner {
      max-width: 560px;
    }

    .hero-fullbleed__subheadline {
      font-size: var(--text-lg);
    }
  }

  /* Desktop */
  @media (min-width: 1200px) {
    .hero-fullbleed__content-inner {
      max-width: 640px;
    }
  }

  /* Mobile — stacked: image top, content below */
  @media (max-width: 767px) {
    .hero-fullbleed {
      display: flex;
      flex-direction: column;
      min-height: auto;
    }

    .hero-fullbleed--full,
    .hero-fullbleed--large,
    .hero-fullbleed--medium {
      min-height: auto;
    }

    .hero-fullbleed__media {
      position: relative;
      aspect-ratio: 4 / 3;
    }

    .hero-fullbleed__content {
      min-height: auto;
      padding-top: var(--space-7);
      padding-bottom: var(--space-8);
      background-color: var(--color-bg-dark);
    }

    .hero-fullbleed__content-inner {
      max-width: 100%;
    }

    .hero-fullbleed--img-left .hero-fullbleed__content,
    .hero-fullbleed--img-right .hero-fullbleed__content {
      justify-content: flex-start;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-fullbleed__headline,
    .hero-fullbleed__subheadline,
    .hero-fullbleed__ctas {
      animation: none;
    }
  }
</style>

{% schema %}
{
  "name": "Hero Fullbleed",
  "tag": "section",
  "class": "section-hero-fullbleed",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "image_left", "label": "Image left / Content right" },
        { "value": "image_right", "label": "Image right / Content left" }
      ],
      "default": "image_right"
    },
    {
      "type": "select",
      "id": "section_height",
      "label": "Section height",
      "options": [
        { "value": "full", "label": "Full (100vh)" },
        { "value": "large", "label": "Large (80vh)" },
        { "value": "medium", "label": "Medium (60vh)" }
      ],
      "default": "full"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "default": 30,
      "unit": "%",
      "info": "Darkens the background image so text stays readable."
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "info": "Small label above headline (optional)."
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Fuel your body, naturally."
    },
    {
      "type": "textarea",
      "id": "subheadline",
      "label": "Subheadline",
      "info": "Supporting copy below headline (optional)."
    },
    {
      "type": "header",
      "content": "Call to action"
    },
    {
      "type": "text",
      "id": "cta_primary_label",
      "label": "Primary button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "cta_primary_url",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "cta_secondary_label",
      "label": "Secondary button label",
      "info": "Leave blank to hide."
    },
    {
      "type": "url",
      "id": "cta_secondary_url",
      "label": "Secondary button link"
    }
  ],
  "presets": [
    {
      "name": "Hero Fullbleed",
      "category": "Hero"
    }
  ]
}
{% endschema %}
