{%- liquid
  assign logo = section.settings.logo
  assign logo_width = section.settings.logo_width
  assign nav_bg = section.settings.nav_background
  assign nav_text = section.settings.nav_text_color
  assign transparent_on_load = section.settings.transparent_on_load
  assign sticky = section.settings.sticky
-%}

<header
  class="nav-sticky{% if transparent_on_load %} nav-sticky--transparent{% endif %}{% if sticky %} nav-sticky--sticky{% endif %}"
  id="section-{{ section.id }}"
  data-section-id="{{ section.id }}"
  data-section-type="nav-sticky"
  data-transparent="{{ transparent_on_load }}"
  style="
    --nav-bg: {{ nav_bg }};
    --nav-text: {{ nav_text }};
    --nav-logo-width: {{ logo_width }}px;
  "
>
  <div class="nav-sticky__bar section-container">
    {%- comment %} Left — Nav links (desktop) / Hamburger (mobile) {%- endcomment -%}
    <nav class="nav-sticky__left" aria-label="Main navigation">
      <button class="nav-sticky__hamburger" type="button" aria-label="Open menu" aria-expanded="false" data-nav-toggle>
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 12h18"/><path d="M3 6h18"/><path d="M3 18h18"/></svg>
      </button>
      <ul class="nav-sticky__links">
        {%- for block in section.blocks -%}
          <li class="nav-sticky__link-item" {{ block.shopify_attributes }}>
            <a href="{{ block.settings.url }}" class="nav-sticky__link">{{ block.settings.label }}</a>
          </li>
        {%- endfor -%}
      </ul>
    </nav>

    {%- comment %} Center — Logo {%- endcomment -%}
    <div class="nav-sticky__center">
      <a href="/" class="nav-sticky__logo-link">
        {%- if logo != blank -%}
          <img
            class="nav-sticky__logo"
            src="{{ logo | image_url: width: 480 }}"
            srcset="
              {{ logo | image_url: width: 240 }} 1x,
              {{ logo | image_url: width: 480 }} 2x
            "
            alt="{{ shop.name }}"
            width="{{ logo_width }}"
            height="{{ logo_width | divided_by: logo.aspect_ratio }}"
            loading="eager"
          >
        {%- else -%}
          <span class="nav-sticky__shop-name">{{ shop.name }}</span>
        {%- endif -%}
      </a>
    </div>

    {%- comment %} Right — Cart {%- endcomment -%}
    <div class="nav-sticky__right">
      <a href="{{ routes.cart_url }}" class="nav-sticky__cart" aria-label="Cart">
        <svg class="nav-sticky__cart-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 01-8 0"/>
        </svg>
        <span class="nav-sticky__cart-count" data-cart-count hidden>0</span>
      </a>
    </div>
  </div>

  {%- comment %} Mobile overlay menu {%- endcomment -%}
  <div class="nav-sticky__mobile-menu" data-nav-menu aria-hidden="true">
    <div class="nav-sticky__mobile-menu-inner">
      <button class="nav-sticky__mobile-close" type="button" aria-label="Close menu" data-nav-close>
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6L6 18"/><path d="M6 6l12 12"/></svg>
      </button>
      <nav class="nav-sticky__mobile-nav" aria-label="Mobile navigation">
        <ul class="nav-sticky__mobile-links">
          {%- for block in section.blocks -%}
            <li>
              <a href="{{ block.settings.url }}" class="nav-sticky__mobile-link">{{ block.settings.label }}</a>
            </li>
          {%- endfor -%}
        </ul>
      </nav>
      <a href="{{ routes.cart_url }}" class="nav-sticky__mobile-cart">
        Cart
        <span data-cart-count hidden>(0)</span>
      </a>
    </div>
  </div>
</header>

<style>
  .nav-sticky {
    position: relative;
    width: 100%;
    z-index: var(--z-sticky);
    background-color: var(--nav-bg);
    color: var(--nav-text);
    transition: background-color var(--transition-base), box-shadow var(--transition-base);
  }

  .nav-sticky--sticky {
    position: sticky;
    top: 0;
  }

  /* Transparent on load — becomes solid on scroll */
  .nav-sticky--transparent {
    background-color: transparent;
  }

  .nav-sticky--scrolled {
    background-color: var(--nav-bg);
    box-shadow: var(--shadow-sm);
  }

  /* Bar layout */
  .nav-sticky__bar {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    height: 64px;
    gap: var(--space-4);
  }

  /* Left — nav links */
  .nav-sticky__left {
    display: flex;
    align-items: center;
  }

  .nav-sticky__links {
    display: none;
    align-items: center;
    gap: var(--space-5);
    list-style: none;
  }

  .nav-sticky__link {
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--nav-text);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    transition: opacity var(--transition-fast);
  }

  .nav-sticky__link:hover {
    opacity: 0.7;
  }

  /* Center — logo */
  .nav-sticky__center {
    display: flex;
    justify-content: center;
  }

  .nav-sticky__logo-link {
    display: inline-flex;
  }

  .nav-sticky__logo {
    width: var(--nav-logo-width);
    height: auto;
    object-fit: contain;
  }

  .nav-sticky__shop-name {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-tight);
    color: var(--nav-text);
  }

  /* Right — cart */
  .nav-sticky__right {
    display: flex;
    justify-content: flex-end;
    align-items: center;
  }

  .nav-sticky__cart {
    position: relative;
    display: inline-flex;
    align-items: center;
    color: var(--nav-text);
    transition: opacity var(--transition-fast);
  }

  .nav-sticky__cart:hover {
    opacity: 0.7;
  }

  .nav-sticky__cart-count {
    position: absolute;
    top: -6px;
    right: -8px;
    min-width: 18px;
    height: 18px;
    padding: 0 4px;
    background-color: var(--color-secondary);
    color: var(--color-text-inverse);
    font-size: 10px;
    font-weight: var(--weight-bold);
    line-height: 18px;
    text-align: center;
    border-radius: var(--radius-full);
  }

  /* Hamburger — mobile only */
  .nav-sticky__hamburger {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    color: var(--nav-text);
    cursor: pointer;
    padding: var(--space-1);
  }

  /* Mobile overlay menu */
  .nav-sticky__mobile-menu {
    position: fixed;
    inset: 0;
    z-index: var(--z-modal);
    background-color: var(--nav-bg);
    color: var(--nav-text);
    transform: translateX(-100%);
    transition: transform var(--duration-slow) var(--ease-out);
    overflow-y: auto;
  }

  .nav-sticky__mobile-menu--open {
    transform: translateX(0);
  }

  .nav-sticky__mobile-menu-inner {
    display: flex;
    flex-direction: column;
    padding: var(--space-6);
    min-height: 100%;
  }

  .nav-sticky__mobile-close {
    align-self: flex-end;
    display: inline-flex;
    background: none;
    border: none;
    color: var(--nav-text);
    cursor: pointer;
    padding: var(--space-1);
    margin-bottom: var(--space-8);
  }

  .nav-sticky__mobile-nav {
    flex-grow: 1;
  }

  .nav-sticky__mobile-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    list-style: none;
  }

  .nav-sticky__mobile-link {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    color: var(--nav-text);
    letter-spacing: var(--tracking-tight);
  }

  .nav-sticky__mobile-cart {
    margin-top: var(--space-8);
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    color: var(--nav-text);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
  }

  /* Desktop */
  @media (min-width: 768px) {
    .nav-sticky__hamburger {
      display: none;
    }

    .nav-sticky__links {
      display: flex;
    }

    .nav-sticky__bar {
      height: 72px;
    }
  }
</style>

<script>
  (function () {
    var header = document.getElementById('section-{{ section.id }}');
    if (!header) return;

    var isTransparent = header.getAttribute('data-transparent') === 'true';
    var toggleBtn = header.querySelector('[data-nav-toggle]');
    var closeBtn = header.querySelector('[data-nav-close]');
    var menu = header.querySelector('[data-nav-menu]');

    // Scroll — transparent to solid
    if (isTransparent) {
      var scrollThreshold = 80;
      function onScroll() {
        if (window.scrollY > scrollThreshold) {
          header.classList.add('nav-sticky--scrolled');
        } else {
          header.classList.remove('nav-sticky--scrolled');
        }
      }
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    }

    // Mobile menu toggle
    if (toggleBtn && menu) {
      toggleBtn.addEventListener('click', function () {
        menu.classList.add('nav-sticky__mobile-menu--open');
        menu.setAttribute('aria-hidden', 'false');
        toggleBtn.setAttribute('aria-expanded', 'true');
        document.body.style.overflow = 'hidden';
      });
    }

    if (closeBtn && menu) {
      closeBtn.addEventListener('click', function () {
        menu.classList.remove('nav-sticky__mobile-menu--open');
        menu.setAttribute('aria-hidden', 'true');
        if (toggleBtn) toggleBtn.setAttribute('aria-expanded', 'false');
        document.body.style.overflow = '';
      });
    }
  })();
</script>

{% schema %}
{
  "name": "Navigation",
  "tag": "header",
  "class": "section-nav-sticky",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo",
      "info": "Falls back to shop name if not set."
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo width",
      "min": 80,
      "max": 240,
      "step": 10,
      "default": 120,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "nav_background",
      "label": "Background color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "nav_text_color",
      "label": "Text color",
      "default": "#1A1A1A"
    },
    {
      "type": "checkbox",
      "id": "transparent_on_load",
      "label": "Transparent on page load",
      "default": false,
      "info": "Background becomes solid after scrolling 80px."
    },
    {
      "type": "checkbox",
      "id": "sticky",
      "label": "Sticky on scroll",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "link",
      "name": "Nav link",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Link"
        },
        {
          "type": "url",
          "id": "url",
          "label": "URL"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Navigation",
      "category": "Header",
      "blocks": [
        { "type": "link", "settings": { "label": "Shop" } },
        { "type": "link", "settings": { "label": "Our Story" } },
        { "type": "link", "settings": { "label": "Subscribe" } },
        { "type": "link", "settings": { "label": "FAQ" } }
      ]
    }
  ]
}
{% endschema %}
