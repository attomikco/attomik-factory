{%- comment -%}
  Renders a product card for use in collection grids.
  Usage: {% render 'product-card', product: product, show_rating: true, show_unit_price: true, lazy: true %}
{%- endcomment -%}

{%- liquid
  assign first_variant = product.selected_or_first_available_variant
  assign available = product.available
  assign has_hover_image = false
  if product.media.size > 1
    assign has_hover_image = true
  endif
-%}

<div class="product-card" data-product-id="{{ product.id }}">
  <a href="{{ product.url }}" class="product-card__media-link">
    <div class="product-card__media{% if has_hover_image %} product-card__media--has-hover{% endif %}">
      {%- if product.featured_image != blank -%}
        <img
          class="product-card__image product-card__image--primary"
          src="{{ product.featured_image | image_url: width: 600 }}"
          srcset="
            {{ product.featured_image | image_url: width: 300 }} 300w,
            {{ product.featured_image | image_url: width: 450 }} 450w,
            {{ product.featured_image | image_url: width: 600 }} 600w
          "
          sizes="(min-width: 1200px) 25vw, (min-width: 768px) 50vw, 66vw"
          alt="{{ product.featured_image.alt | escape | default: product.title }}"
          width="{{ product.featured_image.width }}"
          height="{{ product.featured_image.height }}"
          loading="{{ lazy | default: true | ternary: 'lazy', 'eager' }}"
        >
        {%- if has_hover_image -%}
          <img
            class="product-card__image product-card__image--hover"
            src="{{ product.media[1].preview_image | image_url: width: 600 }}"
            alt="{{ product.media[1].preview_image.alt | escape | default: product.title }}"
            loading="lazy"
          >
        {%- endif -%}
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag: 'product-card__placeholder' }}
      {%- endif -%}

      {%- if product.compare_at_price > product.price -%}
        <span class="product-card__badge">Sale</span>
      {%- endif -%}
    </div>
  </a>

  <div class="product-card__info">
    {%- if show_rating -%}
      {%- render 'rating-stars',
        rating_value: product.metafields.reviews.rating.value,
        rating_count: product.metafields.reviews.rating_count.value,
        rating_product_id: product.id
      -%}
    {%- endif -%}

    <a href="{{ product.url }}" class="product-card__title-link">
      <h3 class="product-card__title">{{ product.title }}</h3>
    </a>

    {%- render 'price', product: product, show_unit_price: show_unit_price -%}

    {%- if product.variants.size > 1 -%}
      <div class="product-card__variants" data-variant-pills>
        {%- for variant in product.variants -%}
          <button
            class="product-card__variant-pill{% if variant == first_variant %} product-card__variant-pill--active{% endif %}{% unless variant.available %} product-card__variant-pill--unavailable{% endunless %}"
            type="button"
            data-variant-id="{{ variant.id }}"
            data-variant-available="{{ variant.available }}"
            data-variant-price="{{ variant.price | money }}"
            {% unless variant.available %}disabled{% endunless %}
            aria-label="{{ variant.title }}"
          >
            {{ variant.title }}
          </button>
        {%- endfor -%}
      </div>
    {%- endif -%}

    <button
      class="product-card__atc btn-primary"
      type="button"
      data-atc
      data-variant-id="{{ first_variant.id }}"
      {% unless available %}disabled{% endunless %}
    >
      {%- if available -%}
        <span data-atc-text>Add to Cart</span>
      {%- else -%}
        <span data-atc-text>Sold Out</span>
      {%- endif -%}
    </button>
  </div>
</div>
