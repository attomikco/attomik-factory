        },
        {
          "type": "review",
          "settings": {
            "review_text": "My whole family loves this. Great knowing it's organic and sustainably sourced. Will keep ordering.",
            "reviewer_name": "David L.",
            "reviewer_subtitle": "Austin, TX"
          }
        }
      ]
    }
  ]
}
{% endschema %}
