{%- liquid
  assign logo = section.settings.logo
  assign tagline = section.settings.tagline
  assign instagram_url = section.settings.instagram_url
  assign tiktok_url = section.settings.tiktok_url
  assign facebook_url = section.settings.facebook_url
  assign bg_color = section.settings.background_color
  assign text_color = section.settings.text_color
  assign border_top = section.settings.border_top_color
-%}

<footer
  class="footer"
  id="section-{{ section.id }}"
  data-section-id="{{ section.id }}"
  data-section-type="footer"
  style="
    --footer-bg: {{ bg_color }};
    --footer-text: {{ text_color }};
    --footer-border-top: {{ border_top }};
  "
>
  <div class="section-container">
    <div class="footer__grid">
      {%- comment %} Column 1 — Brand {%- endcomment -%}
      <div class="footer__brand">
        {%- if logo != blank -%}
          <a href="/" class="footer__logo-link">
            <img
              class="footer__logo"
              src="{{ logo | image_url: width: 320 }}"
              alt="{{ shop.name }}"
              width="120"
              loading="lazy"
            >
          </a>
        {%- else -%}
          <a href="/" class="footer__shop-name">{{ shop.name }}</a>
        {%- endif -%}

        {%- if tagline != blank -%}
          <p class="footer__tagline">{{ tagline }}</p>
        {%- endif -%}

        <div class="footer__social">
          {%- if instagram_url != blank -%}
            <a href="{{ instagram_url }}" class="footer__social-link" aria-label="Instagram" target="_blank" rel="noopener">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            </a>
          {%- endif -%}

          {%- if tiktok_url != blank -%}
            <a href="{{ tiktok_url }}" class="footer__social-link" aria-label="TikTok" target="_blank" rel="noopener">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 00-.79-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.34-6.34V9.42a8.16 8.16 0 004.76 1.52V7.49a4.85 4.85 0 01-1-.8z"/></svg>
            </a>
          {%- endif -%}

          {%- if facebook_url != blank -%}
            <a href="{{ facebook_url }}" class="footer__social-link" aria-label="Facebook" target="_blank" rel="noopener">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
            </a>
          {%- endif -%}
        </div>
      </div>

      {%- comment %} Columns 2–4 — Link columns {%- endcomment -%}
      {%- for block in section.blocks -%}
        <div class="footer__column" {{ block.shopify_attributes }}>
          {%- if block.settings.heading != blank -%}
            <h4 class="footer__column-heading">{{ block.settings.heading }}</h4>
          {%- endif -%}
          {%- if block.settings.links != blank -%}
            <div class="footer__column-links rte">{{ block.settings.links }}</div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

    {%- comment %} Bottom bar {%- endcomment -%}
    <div class="footer__bottom">
      <div class="footer__bottom-left">
        <p class="footer__copyright">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>
        <p class="footer__credit">Developed by Attomik</p>
      </div>

      {%- if shop.enabled_payment_types.size > 0 -%}
        <div class="footer__payment-icons">
          {%- for type in shop.enabled_payment_types -%}
            {{ type | payment_type_svg_tag: class: 'footer__payment-icon' }}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--footer-bg);
    color: var(--footer-text);
    border-top: var(--border-width) solid var(--footer-border-top);
    padding-top: var(--section-gap-md);
    padding-bottom: var(--space-6);
  }

  /* Grid */
  .footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    margin-bottom: var(--space-9);
  }

  /* Brand column */
  .footer__brand {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .footer__logo-link {
    display: inline-flex;
  }

  .footer__logo {
    width: 120px;
    height: auto;
    object-fit: contain;
  }

  .footer__shop-name {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: var(--weight-bold);
    color: var(--footer-text);
  }

  .footer__tagline {
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    opacity: 0.7;
    max-width: 280px;
    color: var(--footer-text);
  }

  /* Social icons */
  .footer__social {
    display: flex;
    gap: var(--space-3);
  }

  .footer__social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: var(--border-width) solid currentColor;
    border-radius: var(--radius-full);
    color: var(--footer-text);
    opacity: 0.6;
    transition: opacity var(--transition-fast);
  }

  .footer__social-link:hover {
    opacity: 1;
  }

  /* Link columns */
  .footer__column-heading {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--footer-text);
    opacity: 0.5;
    margin-bottom: var(--space-4);
  }

  .footer__column-links {
    font-size: var(--text-sm);
    line-height: 2;
    color: var(--footer-text);
  }

  .footer__column-links a {
    color: var(--footer-text);
    opacity: 0.7;
    transition: opacity var(--transition-fast);
  }

  .footer__column-links a:hover {
    opacity: 1;
  }

  .footer__column-links p {
    margin: 0;
    color: inherit;
  }

  /* Bottom bar */
  .footer__bottom {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding-top: var(--space-6);
    border-top: var(--border-width) solid var(--footer-border-top);
  }

  .footer__bottom-left {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .footer__copyright {
    font-size: var(--text-xs);
    opacity: 0.5;
    color: var(--footer-text);
  }

  .footer__credit {
    font-size: var(--text-xs);
    opacity: 0.35;
    color: var(--footer-text);
  }

  /* Payment icons */
  .footer__payment-icons {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    align-items: center;
  }

  .footer__payment-icon {
    height: 24px;
    width: auto;
    opacity: 0.5;
  }

  /* Tablet — 2 columns */
  @media (min-width: 768px) {
    .footer__grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .footer__bottom {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }

  /* Desktop — 4 columns */
  @media (min-width: 1200px) {
    .footer__grid {
      grid-template-columns: 1.5fr 1fr 1fr 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "Footer",
  "tag": "footer",
  "class": "section-footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo",
      "info": "Falls back to shop name."
    },
    {
      "type": "textarea",
      "id": "tagline",
      "label": "Brand tagline",
      "default": "Clean ingredients, real results. Wellness without compromise."
    },
    {
      "type": "header",
      "content": "Social media"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "tiktok_url",
      "label": "TikTok URL"
    },
    {
      "type": "url",
      "id": "facebook_url",
      "label": "Facebook URL"
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#1A1A1A"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "border_top_color",
      "label": "Border top color",
      "default": "#333333"
    }
  ],
  "blocks": [
    {
      "type": "link_column",
      "name": "Link column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Column"
        },
        {
          "type": "richtext",
          "id": "links",
          "label": "Links",
          "default": "<p><a href=\"/\">Link one</a></p><p><a href=\"/\">Link two</a></p><p><a href=\"/\">Link three</a></p>",
          "info": "Add links as richtext — one per line."
        }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Footer",
      "category": "Footer",
      "blocks": [
        {
          "type": "link_column",
          "settings": {
            "heading": "Shop",
            "links": "<p><a href=\"/collections/all\">All Products</a></p><p><a href=\"/collections/bestsellers\">Bestsellers</a></p><p><a href=\"/collections/bundles\">Bundles</a></p>"
          }
        },
        {
          "type": "link_column",
          "settings": {
            "heading": "Company",
            "links": "<p><a href=\"/pages/about\">Our Story</a></p><p><a href=\"/blogs/journal\">Journal</a></p><p><a href=\"/pages/contact\">Contact</a></p>"
          }
        },
        {
          "type": "link_column",
          "settings": {
            "heading": "Support",
            "links": "<p><a href=\"/pages/faq\">FAQ</a></p><p><a href=\"/policies/shipping-policy\">Shipping</a></p><p><a href=\"/policies/refund-policy\">Returns</a></p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
