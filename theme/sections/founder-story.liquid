{%- liquid
  assign image = section.settings.image
  assign layout = section.settings.layout
  assign eyebrow = section.settings.eyebrow
  assign headline = section.settings.headline
  assign body = section.settings.body
  assign cta_label = section.settings.cta_label
  assign cta_url = section.settings.cta_url
  assign founder_name = section.settings.founder_name
  assign founder_title = section.settings.founder_title
  assign bg_color = section.settings.background

  if layout == 'image_left'
    assign layout_class = 'founder-story--img-left'
  else
    assign layout_class = 'founder-story--img-right'
  endif
-%}

<section
  class="founder-story {{ layout_class }}"
  id="section-{{ section.id }}"
  data-section-id="{{ section.id }}"
  data-section-type="founder-story"
  style="--fs-bg: {{ bg_color }};"
>
  <div class="section-container">
    <div class="founder-story__grid">
      <div class="founder-story__media">
        {%- if image != blank -%}
          <img
            class="founder-story__image"
            src="{{ image | image_url: width: 900 }}"
            srcset="
              {{ image | image_url: width: 450 }} 450w,
              {{ image | image_url: width: 600 }} 600w,
              {{ image | image_url: width: 900 }} 900w
            "
            sizes="(min-width: 768px) 45vw, 100vw"
            alt="{{ image.alt | escape }}"
            width="{{ image.width }}"
            height="{{ image.height }}"
            loading="lazy"
          >
        {%- else -%}
          {{ 'lifestyle-2' | placeholder_svg_tag: 'founder-story__placeholder' }}
        {%- endif -%}
      </div>

      <div class="founder-story__content">
        {%- if eyebrow != blank -%}
          <span class="founder-story__eyebrow">{{ eyebrow }}</span>
        {%- endif -%}

        {%- if headline != blank -%}
          <h2 class="founder-story__headline">{{ headline }}</h2>
        {%- endif -%}

        {%- if body != blank -%}
          <div class="founder-story__body rte">{{ body }}</div>
        {%- endif -%}

        {%- if cta_label != blank -%}
          <a href="{{ cta_url }}" class="btn-primary founder-story__cta">{{ cta_label }}</a>
        {%- endif -%}

        {%- if founder_name != blank -%}
          <div class="founder-story__attribution">
            <span class="founder-story__founder-name">— {{ founder_name }}</span>
            {%- if founder_title != blank -%}
              <span class="founder-story__founder-title">, {{ founder_title }}</span>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<style>
  .founder-story {
    background-color: var(--fs-bg);
    padding-top: var(--section-gap-md);
    padding-bottom: var(--section-gap-md);
  }

  /* Grid */
  .founder-story__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-7);
    align-items: center;
  }

  /* Image */
  .founder-story__media {
    overflow: hidden;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
  }

  .founder-story__image {
    width: 100%;
    height: auto;
    aspect-ratio: 3 / 4;
    object-fit: cover;
  }

  .founder-story__placeholder {
    width: 100%;
    aspect-ratio: 3 / 4;
    background-color: var(--color-bg-alt);
  }

  /* Content */
  .founder-story__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .founder-story__eyebrow {
    display: inline-block;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--color-secondary);
  }

  .founder-story__headline {
    line-height: var(--leading-snug);
  }

  /* Richtext body */
  .founder-story__body {
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
  }

  .founder-story__body p {
    margin-bottom: var(--space-4);
  }

  .founder-story__body p:last-child {
    margin-bottom: 0;
  }

  /* CTA */
  .founder-story__cta {
    align-self: flex-start;
    margin-top: var(--space-2);
  }

  /* Attribution */
  .founder-story__attribution {
    margin-top: var(--space-2);
    font-family: var(--font-accent);
    font-size: var(--text-sm);
    font-style: italic;
    color: var(--color-text-secondary);
  }

  .founder-story__founder-name {
    font-weight: var(--weight-medium);
    color: var(--color-text);
  }

  /* Desktop — two columns */
  @media (min-width: 768px) {
    .founder-story__grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-9);
    }

    /* Image left (default) */
    .founder-story--img-left .founder-story__media {
      order: 1;
    }

    .founder-story--img-left .founder-story__content {
      order: 2;
    }

    /* Image right */
    .founder-story--img-right .founder-story__media {
      order: 2;
    }

    .founder-story--img-right .founder-story__content {
      order: 1;
    }
  }

  /* Mobile — image always on top */
  @media (max-width: 767px) {
    .founder-story__media {
      order: 1;
    }

    .founder-story__content {
      order: 2;
    }

    .founder-story__image {
      aspect-ratio: 4 / 5;
    }
  }
</style>

{% schema %}
{
  "name": "Founder Story",
  "tag": "section",
  "class": "section-founder-story",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image",
      "info": "Portrait orientation (3:4) recommended."
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "image_left", "label": "Image left / Content right" },
        { "value": "image_right", "label": "Image right / Content left" }
      ],
      "default": "image_left"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Our Story"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Built from a Kitchen, Backed by Science"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body copy",
      "default": "<p>We started with a simple question: why does healthy have to taste bad? After two years of R&D and hundreds of formulations, we created something we're proud to share with you.</p><p>Every ingredient is intentional. Every decision is transparent. This is wellness without compromise.</p>"
    },
    {
      "type": "header",
      "content": "Call to action"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "info": "Leave blank to hide."
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Attribution"
    },
    {
      "type": "text",
      "id": "founder_name",
      "label": "Founder name",
      "info": "Optional — displayed below CTA."
    },
    {
      "type": "text",
      "id": "founder_title",
      "label": "Founder title",
      "info": "e.g. Co-Founder, CEO"
    },
    {
      "type": "color",
      "id": "background",
      "label": "Background color",
      "default": "#FFFFFF"
    }
  ],
  "presets": [
    {
      "name": "Founder Story",
      "category": "Story"
    }
  ]
}
{% endschema %}
