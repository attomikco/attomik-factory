{% if section.settings.enabled %}
  {% render 'product-badge',
    badge_text: section.settings.badge_text,
    badge_emoji: section.settings.badge_emoji,
    color_scheme: section.settings.color_scheme
  %}
{% endif %}

{% schema %}
{
  "name": "Product Badge",
  "tag": "div",
  "class": "section-product-badge",
  "settings": [
    {
      "type": "checkbox",
      "id": "enabled",
      "label": "Show badge",
      "default": true
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "Premium Quality"
    },
    {
      "type": "text",
      "id": "badge_emoji",
      "label": "Emoji prefix (optional)",
      "info": "Displayed before the text, e.g. ✨ or ✦"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Color scheme",
      "options": [
        { "value": "color__bg-primary color__primary", "label": "Primary" },
        { "value": "color__bg-secondary color__secondary", "label": "Secondary" },
        { "value": "color__bg-tertiary color__tertiary", "label": "Tertiary" },
        { "value": "color__bg-body color__text", "label": "Body" }
      ],
      "default": "color__bg-primary color__primary"
    }
  ],
  "presets": [
    {
      "name": "Product Badge",
      "category": "Product"
    }
  ]
}
{% endschema %}
