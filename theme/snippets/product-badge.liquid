<!-- snippets/product-badge.liquid -->
{% comment %}
  Product eyebrow badge with full style controls.

  Accepts:
  - block: {object} The block object with settings.

  Usage:
    {% render 'product-badge', block: block %}
{% endcomment %}

{%- liquid
  assign bg_opacity = block.settings.bg_opacity | divided_by: 100.0
  assign border_opacity = block.settings.border_opacity | divided_by: 100.0
-%}

<div
  class="w-full px-4"
  style="
    padding-top:{{ block.settings.spacing_top }}px;
    padding-bottom:{{ block.settings.spacing_bottom }}px;
  "
>
  <div
    {{ block.shopify_attributes }}
    style="
      display: inline-flex;
      align-items: center;
      gap: 6px;
      width: fit-content;
      font-family: var(--type__font-heading-family, var(--type__font-body-family, sans-serif));
      font-size: {{ block.settings.font_size }}px;
      font-weight: {{ block.settings.font_weight }} !important;
      text-transform: {{ block.settings.text_transform }};
      letter-spacing: {{ block.settings.letter_spacing }}px;
      color: {{ block.settings.badge_font_color }};
      background-color: {{ block.settings.badge_bg_color | color_modify: 'alpha', bg_opacity }};
      border: {{ block.settings.border_width }}px solid {{ block.settings.border_color | default: block.settings.badge_bg_color | color_modify: 'alpha', border_opacity }};
      border-radius: {{ block.settings.border_radius }}px;
      padding: {{ block.settings.padding_y }}px {{ block.settings.padding_x }}px;
    "
  >
    {% if block.settings.badge_emoji != blank %}
      <span>{{ block.settings.badge_emoji }}</span>
    {% endif %}
    <span>{{ block.settings.badge_text | default: 'Badge Text' }}</span>
  </div>
</div>
