{%- liquid
  assign bg_color = section.settings.background_color
  assign text_color = section.settings.text_color
  assign show_close = section.settings.show_close_button
  assign auto_rotate = section.settings.auto_rotate
  assign block_count = section.blocks.size
-%}

{%- if block_count > 0 -%}
<div
  class="announcement-bar"
  id="section-{{ section.id }}"
  data-section-id="{{ section.id }}"
  data-section-type="announcement-bar"
  data-auto-rotate="{{ auto_rotate }}"
  data-block-count="{{ block_count }}"
  style="
    --ab-bg: {{ bg_color }};
    --ab-text: {{ text_color }};
  "
>
  <div class="announcement-bar__track">
    {%- for block in section.blocks -%}
      <div
        class="announcement-bar__message{% if forloop.first %} announcement-bar__message--active{% endif %}"
        data-ab-message
        {{ block.shopify_attributes }}
      >
        <div class="announcement-bar__text rte">{{ block.settings.text }}</div>
      </div>
    {%- endfor -%}
  </div>

  {%- if show_close -%}
    <button class="announcement-bar__close" type="button" aria-label="Dismiss announcement" data-ab-close>
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6L6 18"/><path d="M6 6l12 12"/></svg>
    </button>
  {%- endif -%}
</div>
{%- endif -%}

<style>
  .announcement-bar {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 40px;
    padding: var(--space-2) var(--space-8);
    background-color: var(--ab-bg);
    color: var(--ab-text);
    text-align: center;
    overflow: hidden;
  }

  .announcement-bar[hidden] {
    display: none;
  }

  /* Track */
  .announcement-bar__track {
    position: relative;
    width: 100%;
    min-height: 1.4em;
  }

  .announcement-bar__message {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity var(--duration-slow) var(--ease-in-out);
    pointer-events: none;
  }

  .announcement-bar__message--active {
    position: relative;
    opacity: 1;
    pointer-events: auto;
  }

  /* Text */
  .announcement-bar__text {
    font-size: var(--text-xs);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-wide);
  }

  .announcement-bar__text a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .announcement-bar__text p {
    margin: 0;
    color: inherit;
  }

  /* Close button */
  .announcement-bar__close {
    position: absolute;
    right: var(--space-3);
    top: 50%;
    transform: translateY(-50%);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-1);
    background: none;
    border: none;
    color: inherit;
    opacity: 0.7;
    cursor: pointer;
    transition: opacity var(--transition-fast);
  }

  .announcement-bar__close:hover {
    opacity: 1;
  }

  @media (min-width: 768px) {
    .announcement-bar__text {
      font-size: var(--text-sm);
    }
  }
</style>

<script>
  (function () {
    var section = document.getElementById('section-{{ section.id }}');
    if (!section) return;

    var storageKey = 'ab-dismissed-{{ section.id }}';

    // Check if dismissed this session
    if (sessionStorage.getItem(storageKey)) {
      section.hidden = true;
      return;
    }

    // Close button
    var closeBtn = section.querySelector('[data-ab-close]');
    if (closeBtn) {
      closeBtn.addEventListener('click', function () {
        section.hidden = true;
        sessionStorage.setItem(storageKey, '1');
      });
    }

    // Auto-rotate
    var autoRotate = section.getAttribute('data-auto-rotate') === 'true';
    var messages = section.querySelectorAll('[data-ab-message]');
    if (autoRotate && messages.length > 1) {
      var current = 0;
      setInterval(function () {
        messages[current].classList.remove('announcement-bar__message--active');
        current = (current + 1) % messages.length;
        messages[current].classList.add('announcement-bar__message--active');
      }, 4000);
    }
  })();
</script>

{% schema %}
{
  "name": "Announcement Bar",
  "tag": "div",
  "class": "section-announcement-bar",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#1A1A1A"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#FFFFFF"
    },
    {
      "type": "checkbox",
      "id": "show_close_button",
      "label": "Show close button",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "auto_rotate",
      "label": "Auto-rotate messages",
      "default": true,
      "info": "Cycles through messages every 4 seconds."
    }
  ],
  "blocks": [
    {
      "type": "message",
      "name": "Message",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Free shipping on orders over $50</p>"
        }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Announcement Bar",
      "category": "Header",
      "blocks": [
        {
          "type": "message",
          "settings": {
            "text": "<p>Free shipping on orders over $50</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
