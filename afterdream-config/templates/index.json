_text","color_border":"outline--width color__outline-divider-1","color_text":"color__text","color_button":"btn--small btn--outline","enable_gradient":false,"text_position":"below","layout_y_alignment":"justify-end","layout_x_alignment":"left","layout_row_span":"row-span-1","layout_col_span":"col-span-1 md:col-span-2"}}},"block_order":["content_6EQNYk","content_qyc4mg"],"name":"t:sections.content_grid.name","settings":{"heading":"","content":"","button_label":"","button_url":"","spacing_top":150,"spacing_bottom":50,"color_scheme":"color__bg-body","color_background":"#ffffff","color_text":"","color_border":"color__border-divider-1","color_button":"btn btn--secondary","enable_color_fade":false,"style_border":"","layout_row_desktop":4,"layout_row_mobile":1,"layout_x_alignment":"justify-between","enable_margin":true,"enable_split":false,"enable_split_heading":false,"visibility":"hidden md:block"}},"accordions_LrLbTK":{"type":"accordions","blocks":{"content_KjJnfW":{"type":"content","settings":{"heading":"How does it make you feel?","content":"<p>Afterdream is designed to help you unwind with intention. With a thoughtful blend of THC and CBD, it offers a gentle, balanced high that promotes relaxation without clouding your clarity. The addition of L-theanine supports a calm, focused state of mind, while Lion’s Mane delivers a subtle lift in mental clarity and mood.<\/p><p>The result is a grounded, lightly elevated experience — perfect for social connection, creative flow, or simply softening the edges of a long day. You feel present, relaxed, and just the right amount of dreamy.<\/p>","icon":"","color_scheme":"btn","enable_open":true}},"content_Kqy98Q":{"type":"content","settings":{"heading":"What does it taste like?","content":"<p>Experience the best of Afterdream with our Tropical, Tangerine, and Lime flavors: <\/p><p>Tropical bursts with juicy pineapple, ripe cherry, and a hint of orange zest; Tangerine delivers bright, juicy citrus with a smooth, uplifting feel; and Lime brings a clean, zesty twist with subtle citrus complexity. Together, they create a vibrant lineup that’s smooth, balanced, and effortlessly drinkable for a calm, clear, and creatively lifted state of mind.<\/p>","icon":"","color_scheme":"btn","enable_open":false}},"content_3jkmy8":{"type":"content","settings":{"heading":"How to enjoy?","content":"<p>Afterdream is best enjoyed lightly chilled, straight from the can for maximum convenience and flavor.<\/p><p>For a slightly more elevated experience, pour it over ice to enhance the effervescence and allow the tropical notes to open up.<\/p><p>No mixers needed — just chill, sip, and enjoy.<\/p>","icon":"","color_scheme":"btn","enable_open":false}},"content_ngLB3x":{"type":"content","settings":{"heading":"Are your products tested?","content":"<p>All of our products have been third-party tested.<\/p><p>You can also find our lab certificates from each batch here: <a href=\"https:\/\/drinkafterdream.com\/pages\/lab-certificates\" title=\"https:\/\/drinkafterdream.com\/pages\/lab-certificates\">Lab Certificates<\/a><\/p>","icon":"","color_scheme":"btn","enable_open":false}},"content_9WdCEU":{"type":"content","settings":{"heading":"Is it legal?","content":"<p>Yes, we use federally legal hemp and lion’s mane mushroom extract to craft something truly unique.<\/p><p>The Delta-9 THC in our drinks is naturally derived from hemp (Cannabis sativa L.) and remains under 0.3% of the product’s net weight—keeping us fully compliant with the 2018 Farm Bill.<\/p>","icon":"","color_scheme":"btn","enable_open":false}},"content_GDRarW":{"type":"content","settings":{"heading":"Where do you ship?","content":"<p>We currently ship to 32+ states across the U.S.<\/p><p>Shipping availability depends on state laws, which are constantly evolving.<\/p><p>We ship wherever it’s legal and compliant with current state regulations.<\/p>","icon":"","color_scheme":"btn","enable_open":false}}},"block_order":["content_KjJnfW","content_Kqy98Q","content_3jkmy8"