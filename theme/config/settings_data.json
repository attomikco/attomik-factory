    "duration_base": 200,
    "duration_slow": 350,
    "duration_slower": 500,
    "animations_enabled": true,
    "sections": {
      "announcement-bar": {
        "type": "announcement-bar",
        "settings": {
          "background_color": "#000000",
          "text_color": "#ffffff",
          "show_close_button": true,
          "auto_rotate": true
        },
        "blocks": {
          "announcement-msg-1": {
            "type": "message",
            "settings": {
              "text": "<p>Free shipping on orders over $50 — <a href=\"/collections/all\">Shop now</a></p>"
            }
          },
          "announcement-msg-2": {
            "type": "message",
            "settings": {
              "text": "<p>Subscribe & save 20% on every order</p>"
            }
          }
        },
        "block_order": ["announcement-msg-1", "announcement-msg-2"]
      },
      "nav-sticky": {
        "type": "nav-sticky",
        "settings": {
          "logo_width": 120,
          "nav_background": "#ffffff",
          "nav_text_color": "#0a0a0a",
          "transparent_on_load": false,
          "sticky": true
        },
        "blocks": {
          "nav-link-1": { "type": "link", "settings": { "label": "Shop", "url": "/collections/all" } },
          "nav-link-2": { "type": "link", "settings": { "label": "Our Story", "url": "/pages/about" } },
          "nav-link-3": { "type": "link", "settings": { "label": "Subscribe", "url": "/pages/subscribe" } },
          "nav-link-4": { "type": "link", "settings": { "label": "FAQ", "url": "/pages/faq" } }
        },
        "block_order": ["nav-link-1", "nav-link-2", "nav-link-3", "nav-link-4"]
      },
      "footer": {
        "type": "footer",
        "settings": {
          "tagline": "Clean ingredients, real results. Wellness without compromise.",
          "instagram_url": "",
          "tiktok_url": "",
          "facebook_url": "",
          "background_color": "#0a0a0a",
          "text_color": "#ffffff",
          "border_top_color": "#222222"
        },
        "blocks": {
          "footer-col-1": {
            "type": "link_column",
            "settings": {
              "heading": "Shop",
              "links": "<p><a href=\"/collections/all\">All Products</a></p><p><a href=\"/collections/bestsellers\">Bestsellers</a></p><p><a href=\"/collections/bundles\">Bundles</a></p>"
            }
          },
          "footer-col-2": {
            "type": "link_column",
            "settings": {
              "heading": "Company",
              "links": "<p><a href=\"/pages/about\">Our Story</a></p><p><a href=\"/blogs/journal\">Journal</a></p><p><a href=\"/pages/contact\">Contact</a></p>"
            }
          },
          "footer-col-3": {
            "type": "link_column",
            "settings": {
              "heading": "Support",
              "links": "<p><a href=\"/pages/faq\">FAQ</a></p><p><a href=\"/policies/shipping-policy\">Shipping</a></p><p><a href=\"/policies/refund-policy\">Returns</a></p>"
            }
          }
        },
        "block_order": ["footer-col-1", "footer-col-2", "footer-col-3"]
