{%- liquid
  assign section_title = section.settings.section_title
  assign section_subtitle = section.settings.section_subtitle
  assign close_others = section.settings.close_others
  assign bg_color = section.settings.background
  assign bg_image = section.settings.background_image
-%}

<section
  class="faq-accordion"
  id="section-{{ section.id }}"
  data-section-id="{{ section.id }}"
  data-section-type="faq-accordion"
  data-close-others="{{ close_others }}"
  style="--faq-bg: {{ bg_color }};"
>
  {%- if bg_image != blank -%}
    <img
      class="faq-accordion__bg-image"
      src="{{ bg_image | image_url: width: 1800 }}"
      alt=""
      loading="lazy"
    >
  {%- endif -%}

  <div class="section-container faq-accordion__container">
    {%- if section_title != blank or section_subtitle != blank -%}
      <div class="faq-accordion__header">
        {%- if section_title != blank -%}
          <h2 class="faq-accordion__title">{{ section_title }}</h2>
        {%- endif -%}
        {%- if section_subtitle != blank -%}
          <p class="faq-accordion__subtitle">{{ section_subtitle }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="faq-accordion__list">
      {%- for block in section.blocks -%}
        <details class="faq-accordion__item" {{ block.shopify_attributes }}>
          <summary class="faq-accordion__question">
            <span class="faq-accordion__question-text">{{ block.settings.question }}</span>
            <svg class="faq-accordion__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9l6 6 6-6"/></svg>
          </summary>
          <div class="faq-accordion__answer-wrap">
            <div class="faq-accordion__answer rte">
              {{ block.settings.answer }}
            </div>
          </div>
        </details>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .faq-accordion {
    position: relative;
    background-color: var(--faq-bg);
    padding-top: var(--section-gap-md);
    padding-bottom: var(--section-gap-md);
    overflow: hidden;
  }

  .faq-accordion__bg-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.06;
    pointer-events: none;
  }

  .faq-accordion__container {
    position: relative;
    z-index: var(--z-dropdown);
    max-width: var(--width-content);
  }

  /* Header */
  .faq-accordion__header {
    text-align: center;
    margin-bottom: var(--space-8);
  }

  .faq-accordion__subtitle {
    max-width: var(--width-narrow);
    margin-left: auto;
    margin-right: auto;
    color: var(--color-text-secondary);
  }

  /* List */
  .faq-accordion__list {
    max-width: var(--width-narrow);
    margin-left: auto;
    margin-right: auto;
  }

  /* Item */
  .faq-accordion__item {
    border-bottom: var(--border-width) solid var(--color-border);
  }

  .faq-accordion__item:first-child {
    border-top: var(--border-width) solid var(--color-border);
  }

  /* Question / summary */
  .faq-accordion__question {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-5) 0;
    cursor: pointer;
    list-style: none;
    font-family: var(--font-heading);
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-snug);
    color: var(--color-text);
    transition: color var(--transition-fast);
  }

  .faq-accordion__question::-webkit-details-marker {
    display: none;
  }

  .faq-accordion__question::marker {
    content: '';
  }

  .faq-accordion__question:hover {
    color: var(--color-secondary);
  }

  .faq-accordion__question-text {
    flex: 1;
  }

  /* Chevron */
  .faq-accordion__chevron {
    flex-shrink: 0;
    color: var(--color-text-muted);
    transition: transform var(--transition-base);
  }

  .faq-accordion__item[open] .faq-accordion__chevron {
    transform: rotate(180deg);
  }

  /* Answer wrapper — animated via JS max-height */
  .faq-accordion__answer-wrap {
    overflow: hidden;
    transition: max-height var(--duration-slow) var(--ease-out);
  }

  .faq-accordion__answer {
    padding-bottom: var(--space-5);
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--color-text-secondary);
  }

  .faq-accordion__answer p {
    margin-bottom: var(--space-3);
  }

  .faq-accordion__answer p:last-child {
    margin-bottom: 0;
  }

  .faq-accordion__answer a {
    color: var(--color-text-link);
    text-decoration: underline;
  }

  /* Desktop */
  @media (min-width: 768px) {
    .faq-accordion__question {
      font-size: var(--text-md);
      padding: var(--space-5) 0;
    }
  }
</style>

<script>
  (function () {
    var section = document.getElementById('section-{{ section.id }}');
    if (!section) return;

    var closeOthers = section.getAttribute('data-close-others') === 'true';
    var items = section.querySelectorAll('.faq-accordion__item');

    items.forEach(function (detail) {
      var summary = detail.querySelector('.faq-accordion__question');
      var wrap = detail.querySelector('.faq-accordion__answer-wrap');
      if (!summary || !wrap) return;

      summary.addEventListener('click', function (e) {
        e.preventDefault();

        if (detail.open) {
          // Close
          wrap.style.maxHeight = wrap.scrollHeight + 'px';
          requestAnimationFrame(function () {
            wrap.style.maxHeight = '0px';
          });
          wrap.addEventListener('transitionend', function handler() {
            detail.open = false;
            wrap.style.maxHeight = '';
            wrap.removeEventListener('transitionend', handler);
          });
        } else {
          // Close others
          if (closeOthers) {
            items.forEach(function (other) {
              if (other !== detail && other.open) {
                var otherWrap = other.querySelector('.faq-accordion__answer-wrap');
                if (otherWrap) {
                  otherWrap.style.maxHeight = otherWrap.scrollHeight + 'px';
                  requestAnimationFrame(function () {
                    otherWrap.style.maxHeight = '0px';
                  });
                  otherWrap.addEventListener('transitionend', function handler() {
                    other.open = false;
                    otherWrap.style.maxHeight = '';
                    otherWrap.removeEventListener('transitionend', handler);
                  });
                }
              }
            });
          }

          // Open
          detail.open = true;
          var fullHeight = wrap.scrollHeight + 'px';
          wrap.style.maxHeight = '0px';
          requestAnimationFrame(function () {
            wrap.style.maxHeight = fullHeight;
          });
          wrap.addEventListener('transitionend', function handler() {
            wrap.style.maxHeight = '';
            wrap.removeEventListener('transitionend', handler);
          });
        }
      });
    });
  })();
</script>

{% schema %}
{
  "name": "FAQ Accordion",
  "tag": "section",
  "class": "section-faq-accordion",
  "settings": [
    {
      "type": "text",
      "id": "section_title",
      "label": "Title",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "textarea",
      "id": "section_subtitle",
      "label": "Subtitle",
      "info": "Optional description below the title."
    },
    {
      "type": "checkbox",
      "id": "close_others",
      "label": "Close other items when opening one",
      "default": true,
      "info": "Accordion behavior — only one answer visible at a time."
    },
    {
      "type": "color",
      "id": "background",
      "label": "Background color",
      "default": "#FFFFFF"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image",
      "info": "Optional — subtle lifestyle image shown at low opacity."
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "FAQ item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Question"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Answer text goes here.</p>"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "FAQ Accordion",
      "category": "Text",
      "blocks": [
        {
          "type": "item",
          "settings": {
            "question": "What ingredients do you use?",
            "answer": "<p>We use only certified organic, non-GMO ingredients. Every batch is third-party tested for purity and potency. You can view our full ingredient list on each product page.</p>"
          }
        },
        {
          "type": "item",
          "settings": {
            "question": "How does subscription work?",
            "answer": "<p>Choose your products and delivery frequency. You'll save 20% on every order and get free shipping. You can skip, pause, or cancel anytime from your account dashboard — no commitments.</p>"
          }
        },
        {
          "type": "item",
          "settings": {
            "question": "What is your return policy?",
            "answer": "<p>We offer a 30-day satisfaction guarantee. If you're not happy with your purchase, contact us and we'll make it right with a full refund or replacement — no questions asked.</p>"
          }
        },
        {
          "type": "item",
          "settings": {
            "question": "Where do you ship?",
            "answer": "<p>We ship to all 50 US states. Orders over $50 qualify for free standard shipping. Expedited shipping options are available at checkout. We're working on expanding internationally.</p>"
          }
        },
        {
          "type": "item",
          "settings": {
            "question": "Are your products vegan and gluten-free?",
            "answer": "<p>Yes — all of our products are 100% plant-based, gluten-free, and free from the top 8 allergens. We manufacture in a dedicated facility to prevent cross-contamination.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
